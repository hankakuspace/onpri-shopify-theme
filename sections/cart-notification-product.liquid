{%- if cart != empty -%}
  {%- for item in cart.items -%}
    <div id="cart-notification-product-{{ item.key }}" class="cart-item">
      {%- if item.image -%}
        <div class="cart-notification-product__image global-media-settings">
          <img
            src="{{ item.image | image_url: width: 140 }}"
            alt="{{ item.image.alt | escape }}"
            width="70"
            height="{{ 70 | divided_by: item.image.aspect_ratio | ceil }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}
      <div>
        {%- if settings.show_vendor -%}
          <p class="caption-with-letter-spacing light">{{ item.product.vendor }}</p>
        {%- endif -%}
        <h3 class="cart-notification-product__name h4">{{ item.product.title | escape }}</h3>
        <dl>
          {%- unless item.product.has_only_default_variant -%}
            {%- for option in item.options_with_values -%}
              <div class="product-option">
                <dt>{{ option.name }}:</dt>
                <dd>{{ option.value }}</dd>
              </div>
            {%- endfor -%}
          {%- endunless -%}
          {%- assign onpri_preview_image_url = '' -%}
                          {%- assign has_onpri_customization = false -%}
                          {%- for property in item.properties -%}
                            {%- if property.first == 'ONPRIプレビュー画像URL' and property.last != blank -%}
                              {%- assign onpri_preview_image_url = property.last -%}
                            {%- endif -%}
                            {%- if property.first contains 'ONPRI' and property.last != blank -%}
                              {%- assign has_onpri_customization = true -%}
                            {%- endif -%}
                          {%- endfor -%}

                          {%- if has_onpri_customization -%}
                            <div class="product-option">
                              <span>カスタマイズ済み</span>
                            </div>
                            {%- if onpri_preview_image_url != blank -%}
                              <div class="product-option onpri-cart-preview">
                                <button
                                  type="button"
                                  onclick="
                                    (function() {
                                      var existing = document.getElementById('OnpriPreviewLightbox');
                                      if (existing) existing.remove();

                                      var overlay = document.createElement('div');
                                      overlay.id = 'OnpriPreviewLightbox';
                                      overlay.style.position = 'fixed';
                                      overlay.style.inset = '0';
                                      overlay.style.zIndex = '2147483647';
                                      overlay.style.display = 'flex';
                                      overlay.style.alignItems = 'center';
                                      overlay.style.justifyContent = 'center';
                                      overlay.style.padding = '24px';
                                      overlay.style.background = 'rgba(0, 0, 0, 0.82)';

                                      var panel = document.createElement('div');
                                      panel.style.position = 'relative';
                                      panel.style.width = 'min(90vw, 720px)';
                                      panel.style.maxHeight = '90vh';
                                      panel.style.padding = '24px';
                                      panel.style.borderRadius = '12px';
                                      panel.style.background = '#fff';
                                      panel.style.boxShadow = '0 20px 60px rgba(0, 0, 0, 0.35)';

                                      var closeButton = document.createElement('button');
                                      closeButton.type = 'button';
                                      closeButton.textContent = '×';
                                      closeButton.setAttribute('aria-label', 'ONPRIプレビュー画像を閉じる');
                                      closeButton.style.position = 'absolute';
                                      closeButton.style.top = '12px';
                                      closeButton.style.right = '12px';
                                      closeButton.style.zIndex = '2147483647';
                                      closeButton.style.border = '0';
                                      closeButton.style.background = '#111';
                                      closeButton.style.color = '#fff';
                                      closeButton.style.width = '32px';
                                      closeButton.style.height = '32px';
                                      closeButton.style.borderRadius = '50%';
                                      closeButton.style.cursor = 'pointer';

                                      var image = document.createElement('img');
                                      image.src = '{{ onpri_preview_image_url }}';
                                      image.alt = '{{ item.product.title | escape }} ONPRIプレビュー';
                                      image.style.display = 'block';
                                      image.style.width = '100%';
                                      image.style.maxHeight = '80vh';
                                      image.style.objectFit = 'contain';
                                      image.style.background = '#fff';

                                      function closeLightbox() {
                                        overlay.remove();
                                        document.documentElement.style.overflow = '';
                                      }

                                      closeButton.onclick = closeLightbox;
                                      overlay.onclick = function(event) {
                                        if (event.target === overlay) closeLightbox();
                                      };

                                      panel.appendChild(closeButton);
                                      panel.appendChild(image);
                                      overlay.appendChild(panel);
                                      document.body.appendChild(overlay);
                                      document.documentElement.style.overflow = 'hidden';
                                    })();
                                  "
                                  style="padding: 0; border: 0; background: transparent; cursor: zoom-in;"
                                  aria-label="ONPRIプレビュー画像を拡大表示"
                                >
                                  <img
                                    src="{{ onpri_preview_image_url }}"
                                    alt="{{ item.product.title | escape }} ONPRIプレビュー"
                                    style="width: 72px; height: 72px; object-fit: contain; border: 1px solid #ddd; border-radius: 8px; background: #fff;"
                                  >
                                </button>
                              </div>
                            {%- endif -%}
                          {%- endif -%}

                          {%- for property in item.properties -%}
            {%- assign property_first_char = property.first | slice: 0 -%}
                            {%- assign is_onpri_property = false -%}
                            {%- if property.first contains 'ONPRI' or property.first == '_onpri_brand_id' -%}
                              {%- assign is_onpri_property = true -%}
                            {%- endif -%}
            {%- if property.last != blank and property_first_char != '_' and is_onpri_property == false -%}
              <div class="product-option">
                <dt>{{ property.first }}:</dt>
                <dd>
                  {%- if property.last contains '/uploads/' -%}
                    <a href="{{ property.last }}" class="link" target="_blank">
                      {{ property.last | split: '/' | last }}
                    </a>
                  {%- else -%}
                    {{ property.last }}
                  {%- endif -%}
                </dd>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </dl>
        {%- if item.selling_plan_allocation != null -%}
          <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
{%- endif -%}
